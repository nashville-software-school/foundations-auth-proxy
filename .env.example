PORT=3000

# Plain JSON (not base64) — the local server accepts both formats.
# Copy this file to .env and fill in real values. Never commit .env.
# For the full format, see the SITES_SECRETS section in README.md.
SITES_SECRETS={"foundations-course":{"clientId":"YOUR_GITHUB_CLIENT_ID","clientSecret":"YOUR_GITHUB_CLIENT_SECRET"},"client-side-curriculum":{"clientId":"YOUR_GITHUB_CLIENT_ID","clientSecret":"YOUR_GITHUB_CLIENT_SECRET"}}
